# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                        # openssl rand -base64 32

# SSO Onfly (OAuth)
ONFLY_CLIENT_ID=
ONFLY_CLIENT_SECRET=

# Restrição de domínio de email (default: onfly.com.br)
ALLOWED_EMAIL_DOMAIN=onfly.com.br

# Anthropic (Claude) — sk-ant-...
ANTHROPIC_API_KEY=

# BigQuery
BIGQUERY_PROJECT_ID=dw-onfly-prd

# Opção A: JSON da service account inline (minificado, sem quebras de linha)
GOOGLE_CREDENTIALS_JSON=

# Opção B: caminho para o arquivo de credenciais
GOOGLE_APPLICATION_CREDENTIALS=

# LinkedIn OAuth
# Registrar redirect URI exata em: linkedin.com/developers/apps → Auth → Authorized redirect URLs
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# Criptografia de tokens em repouso (AES-256-GCM, 32 bytes)
# openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=